# .envrc

# This file can be used by direnv to automatically activate a nix
# environment in this folder. See
# https://nixos.wiki/wiki/Flakes#Direnv_integration for more information

use flake
watch_file poetry.lock
watch_file pyproject.toml

# Playwright 1.60.0 expects browser revision 1223, but nixpkgs provides 1217.
# Symlinks in ~/.playwright-browsers bridge the gap.
export PLAYWRIGHT_BROWSERS_PATH="$HOME/.playwright-browsers"
