# GTD vault configuration
GTD_REPO_URL=git@gitlab.com:charlesbaynham/gtd.git
GTD_GIT_BRANCH=master
GTD_DIR=~/gtd

# Git identity (optional — uses container defaults if not set)
# GIT_USER_NAME=Charles
# GIT_USER_EMAIL=charles@example.com

# reMarkable configuration
REMARKABLE_FOLDER=GTD Daily

# Path to rmapi binary (default: rmapi in $PATH)
# RMAPI_BIN=/usr/local/bin/rmapi

# SSH key for git operations
# Place your private key at secrets/ssh_private_key
# It will be mounted as a Docker secret
SSH_PRIVATE_KEY=/run/secrets/ssh_private_key
